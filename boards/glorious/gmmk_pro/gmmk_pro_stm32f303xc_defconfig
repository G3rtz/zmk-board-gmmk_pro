# Common options for STM32F303XC board target.
#
# Keep this target explicitly ZMK-compatible so builds that resolve to the
# non-variant SoC target still pass the Zephyr 4.1 ZMK board-compat check.

CONFIG_SOC_SERIES_STM32F3X=y
CONFIG_SOC_STM32F303XC=y

CONFIG_BOARD_GMMK_PRO=y
CONFIG_CORTEX_M_SYSTICK=y

CONFIG_CLOCK_CONTROL=y
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=72000000

CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_CDC_ACM=n
CONFIG_ZMK_USB=y

CONFIG_ZMK_BOARD_COMPAT=y

CONFIG_SERIAL=y
CONFIG_UART_INTERRUPT_DRIVEN=y

CONFIG_MAIN_STACK_SIZE=4096
CONFIG_HEAP_MEM_POOL_SIZE=4096

CONFIG_ZMK_HID_REPORT_TYPE_NKRO=y
