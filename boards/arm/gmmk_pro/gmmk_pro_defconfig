# Board-level Kconfig defaults for GMMK Pro

# SoC
CONFIG_SOC_SERIES_STM32F3X=y
CONFIG_SOC_STM32F303XC=y
CONFIG_SYS_CLOCK_HW_CYCLES_PER_SEC=72000000

# Board
CONFIG_BOARD_GMMK_PRO=y

# GPIO
CONFIG_GPIO=y

# Pin Control
CONFIG_PINCTRL=y

# Clock
CONFIG_CLOCK_CONTROL=y

# USB
CONFIG_USB_DEVICE_STACK=y
CONFIG_USB_DEVICE_VID=0x320F
CONFIG_USB_DEVICE_PID=0x5044
CONFIG_USB_DEVICE_MANUFACTURER="Glorious"
CONFIG_USB_DEVICE_PRODUCT="GMMK Pro"

# Bootloader
CONFIG_BOOTLOADER_STM32_DFU=y

# Flash/NVS for settings storage
CONFIG_FLASH=y
CONFIG_FLASH_MAP=y
CONFIG_NVS=y
CONFIG_SETTINGS=y
CONFIG_SETTINGS_NVS=y

# Encoder
CONFIG_EC11=y
CONFIG_EC11_TRIGGER_GLOBAL_THREAD=y

# HID
CONFIG_ZMK_HID_REPORT_TYPE_NKRO=y
